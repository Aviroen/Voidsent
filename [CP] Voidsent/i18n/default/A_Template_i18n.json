 /*
 All [NORMAL] daily dialogue can have trigger actions from any of the frameworks added, these are called {By Index} and here is the {Index Number} the <blanks> need to be <filled in> [boxes are optional and can be removed]
 these are all already appended with the action and a SPACE, so they should look something like ${1}100 Combat / if you wanted to add 100 exp to combat
 {0} = {{ModId}}

 {1} = BETAS_AddExperience [#Amount] [Skill]
 {2} = BETAS_ChangeMusicTrack <Track>
 {3} = BETAS_ChangeRelationship {{ModId}}_<NPC> [Relationship] [Roommates?] [#Wedding Delay]
 {4} = BETAS_DialogueBox <Message> [Portrait] [DisplayName] [Typing?] //this is supplied to a {{ModId}}_FakeNPC since calling a real NPC will screw with yapper
 {5} = BETAS_EatObject <ItemId> [From Inventory?]
 {6} = BETAS_EmoteFarmer <#EmoteId>
 {7} = BETAS_EmoteNpc {{ModId}}_<NPC> <#EmoteId>
 {8} = BETAS_Explode [#X] [#Y] [#Radius] [Damaging?] [#Damage] [Destroy?]
 {9} = BETAS_Jump [Character] [#Velocity] [#Vertical Movement] [#Horizontal Movement]
 {10} = BETAS_Lightning [#X] [#Y]
 {11} = BETAS_Message <Text> [Typing?]
 {12} = BETAS_OpenShop <ShopId> [Owner]
 {13} = BETAS_PlaySound <Cue Name> [Everyone?]
 {14} = BETAS_SetFriendshipPoints {{ModId}}_<NPC> <#Points>
 {15} = BETAS_SetHealth <#Value> [Override?]
 {16} = BETAS_SetStamina <#Value> [Override?]
 {17} = BETAS_ShakeNpc {{ModId}}_[NPC] [#Duration]
 {18} = BETAS_ShowMail {{ModId}}_<Mail Id> [Flag?]
 {19} = BETAS_TextAboveHead {{ModId}}_<NPC> <Dialogue> [#Duration] [#Delay] [Jitter?] [Colour]
 {20} = BETAS_UpdateAppearance {{ModId}}_<NPC> [Id]
 {21} = BETAS_WarpFarmer <Location> <#X> <#Y> <#FacingDirection>
 {22} = BETAS_WarpNpc {{ModId}}_<NPC> <Location> <#X> <#Y> <#FacingDirection>
 {23} = BETAS_WeatherForTomorrow <ContextID> <Weather>
 {24} = mushymato.MMAP_ShowConstructForCurrent <builder> [restrict]
 {25} = mushymato.MMAP_ShowShipping
 {26} = mushymato.MMAP_ShowBag <bagInventoryId> [bagKind]
 {27} = mushymato.MMAP_AddItemToBag <bagInventoryId> <qualifiedItemId> [amount] [quality]
 {28} = mushymato.MMAP_TAS <X> <Y> <tasId>+ 
 {29} = mushymato.MMAP_Critter <X> <Y> [<critterType> [type dependent args]]+
 {30} = mushymato.MMAP_CritterRandom <chance> [<critterType> [type dependent args]]+
 {31} = mushymato.MMAP_WrpHere [X Y] [facingDirection] [fadeToBlack] [relative] [audioCue]
 {32} = mushymato.MMAP_QuestionDialogue <question_dialog_id> [included responses]+
 {33} = mushymato.MMAP_LaunchFireworks [type] [launchTx[:x:y:width:height]]
 {34} = mushymato.MMAP_PlaySound <audioName> [pitches] [isGlobal]
 */
